  "homepage": "https://github.com/markodera/hvt-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markodera/hvt-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/markodera/hvt-sdk/issues"
  },
